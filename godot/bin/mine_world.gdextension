[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/libsky_miner.so"
linux.release.x86_64 =   "res://../rust/target/release/libsky_miner.so"
windows.debug.x86_64 =   "res://../rust/target/debug/sky_miner.dll"
windows.release.x86_64 = "res://../rust/target/release/sky_miner.dll"
macos.debug =            "res://../rust/target/debug/libsky_miner.dylib"
macos.release =          "res://../rust/target/release/libsky_miner.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/libsky_miner.dylib"
macos.release.arm64 =    "res://../rust/target/release/libsky_miner.dylib"
